<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml" spacing="8" stylesheets="@PersonDetails.css" styleClass="details-panel">

    <Label text="Person Details" styleClass="details-heading" />

    <ScrollPane VBox.vgrow="ALWAYS"
                fitToWidth="false"
                fitToHeight="true"
                hbarPolicy="AS_NEEDED"
                stylesheets="@PersonDetails.css"
                styleClass="details-scroll-pane">
        <content>
            <VBox spacing="8" styleClass="details-panel">
                <HBox spacing="5">
                    <Label text="Name:" styleClass="field-name" />
                    <Label fx:id="name" styleClass="field-value" />
                </HBox>

                <HBox spacing="5">
                    <Label text="Phone:" styleClass="field-name" />
                    <Label fx:id="phone" styleClass="field-value" />
                </HBox>

                <HBox spacing="5">
                    <Label text="Email:" styleClass="field-name" />
                    <Label fx:id="email" styleClass="field-value" />
                </HBox>

                <HBox spacing="5">
                    <Label text="Address:" styleClass="field-name" />
                    <Label fx:id="address" styleClass="field-value" />
                </HBox>

                <VBox spacing="6">
                    <Label text="Notes:" styleClass="field-name" />
                    <FlowPane fx:id="notes" hgap="8" vgap="8" />
                </VBox>
            </VBox>
        </content>
    </ScrollPane>
</VBox>
