<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<HBox id="cardPane" fx:id="cardPane" spacing="0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
  <StackPane styleClass="card-index-box" minWidth="32" prefWidth="32" maxWidth="32">
    <Label fx:id="id" styleClass="card-index-label" />
  </StackPane>
  <GridPane HBox.hgrow="ALWAYS">
    <columnConstraints>
      <ColumnConstraints hgrow="SOMETIMES" minWidth="10" prefWidth="150" />
    </columnConstraints>
    <VBox alignment="CENTER_LEFT" minHeight="64" spacing="4" GridPane.columnIndex="0">
      <padding>
        <Insets top="6" right="8" bottom="6" left="10" />
      </padding>
      <Label fx:id="name" text="\$first" styleClass="cell_big_label" />
      <FlowPane fx:id="tags" />
    </VBox>
  </GridPane>
</HBox>
