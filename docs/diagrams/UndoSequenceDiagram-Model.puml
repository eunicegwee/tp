@startuml
!include style.puml
skinparam ArrowFontStyle plain

box Logic LOGIC_COLOR_T1
participant "a:AddCommand" as AddCommand LOGIC_COLOR
end box

box Model MODEL_COLOR_T1
participant ":Model" as Model MODEL_COLOR
end box

[-> AddCommand : execute(model)
activate AddCommand

AddCommand -> Model : addPerson(toAdd)
activate Model
Model --> AddCommand
deactivate Model

AddCommand -> Model : addTags(toAdd)
activate Model
Model --> AddCommand
deactivate Model

AddCommand -> Model : setUndoAction(undoRunnable)
activate Model
Model --> AddCommand
deactivate Model
note right : undoRunnable reverses the add:\n  model.deletePerson(toAdd)\n  model.deleteTags(toAdd)

AddCommand --> [ : result
deactivate AddCommand

@enduml
